{
  "name": "pi-mesh",
  "version": "0.1.0",
  "description": "Zero-daemon agent mesh for Pi — task board, file reservations, and agent-to-agent messaging",
  "type": "module",
  "main": "./dist/extension/index.js",
  "types": "./dist/extension/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/extension/index.d.ts",
      "default": "./dist/extension/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "node --test --import jiti/register 'src/**/*.test.ts'",
    "test:all": "node --test --import jiti/register 'src/**/*.test.ts' 'test/**/*.test.ts'",
    "test:ci": "CI=true node --test --import jiti/register 'src/**/*.test.ts' 'test/**/*.test.ts'"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "mesh",
    "multi-agent",
    "coordination"
  ],
  "files": [
    "dist/**/*",
    "*.json",
    "README.md"
  ],
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.74.0"
  },
  "optionalDependencies": {
    "pi-workflows": ">=0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "jiti": "^2.7.0",
    "typebox": "^1.1.38",
    "typescript": "^5.9.3"
  },
  "license": "MIT"
}
