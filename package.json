{
  "name": "pi-mesh",
  "version": "0.1.0",
  "description": "Zero-daemon agent mesh for Pi \u2014 task board, file reservations, and agent-to-agent messaging",
  "type": "module",
  "pi": {
    "extensions": [
      "./src/extension/index.ts"
    ]
  },

  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:all": "vitest run",
    "test:ci": "vitest run"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "mesh",
    "multi-agent",
    "coordination"
  ],
  "files": [
    "src/",
    "*.json",
    "README.md"
  ],
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.74.0"
  },
  "optionalDependencies": {
    "pi-workflows": ">=0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "typebox": "^1.1.38",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  },
  "license": "MIT"
}